@model ExternalQueryManageViewModel
@{
    ViewData["Title"] = "Manage External Query";
    var assignedUsers = ViewBag.AssignedUsers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Manage Query #@Model.Id</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6"><strong>Name:</strong> @Model.FullName</div>
            <div class="col-md-6"><strong>Email:</strong> @Model.Email</div>
            <div class="col-md-6"><strong>Phone:</strong> @(Model.PhoneNumber ?? "N/A")</div>
            <div class="col-md-6"><strong>Organisation:</strong> @(Model.OrganisationName ?? "N/A")</div>
            <div class="col-12"><strong>Subject:</strong> @Model.QuerySubject</div>
            <div class="col-12">
                <strong>Message:</strong>
                <pre class="bg-light p-3 rounded border mt-2">@Model.Message</pre>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Update Query</div>
    <div class="card-body">
        <form asp-action="Details" method="post" class="mb-3">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<ExternalQueryStatus>()" class="form-select"></select>
                </div>

                <div class="col-md-8">
                    <label asp-for="AssignedToUserId" class="form-label"></label>
                    <select asp-for="AssignedToUserId" asp-items="assignedUsers" class="form-select">
                        <option value="">Unassigned</option>
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="ResponseNotes" class="form-label"></label>
                    <textarea asp-for="ResponseNotes" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="ResponseNotes" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Update</button>
            </div>
        </form>

        @if (User.IsInRole("Admin"))
        {
            <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this query?');">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">Delete Query</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
